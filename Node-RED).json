    {
        "id": "24abb7115029c420",
        "type": "function",
        "z": "smart_farm_pro_tab",
        "name": "Đóng gói Lệnh Thủ Công",
        "func": "flow.set(\"manual_\" + msg.topic, msg.payload);\n\nif (flow.get(\"mode\") === \"MANUAL\") {\n    let p = flow.get(\"manual_pump\") ? \"ON\" : \"OFF\";\n    let l = flow.get(\"manual_light\") ? \"ON\" : \"OFF\";\n    let r = flow.get(\"manual_roof\") ? \"OPEN\" : \"CLOSED\";\n\n    let msgMqtt = {\n        payload: { cmd: \"control\", pump: p, light: l, roof: r }\n    };\n    let msgFbControl = {\n        payload: { pump: p, light: l, roof: r }\n    };\n    return [msgMqtt, msgFbControl];\n}\nreturn [null, null];",
