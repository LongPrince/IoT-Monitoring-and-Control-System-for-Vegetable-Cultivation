    {
        "id": "b0979a963091e4cf",
        "type": "function",
        "z": "smart_farm_pro_tab",
        "name": "Lọc Spam & Soạn Email",
        "func": "let isCritical = msg.payload.isCritical;\nlet status = msg.payload.status;\nlet lastAlert = flow.get(\"lastEmailAlert\") || \"\";\n\n// Nếu có lỗi VÀ lỗi này khác với lỗi vừa gửi mail (chống spam)\nif (isCritical && status !== lastAlert) {\n    flow.set(\"lastEmailAlert\", status); // Lưu lại lịch sử\n    \n    // Soạn nội dung email\n    msg.topic = \"🚨 CẢNH BÁO SMART FARM: \" + status;\n    msg.payload = \"Hệ thống phát hiện sự cố trên Node-RED.\\n\\n\" +\n                  \"📌 Vấn đề: \" + status + \"\\n\" +\n                  \"⏱️ Thời gian: \" + new Date().toLocaleString() + \"\\n\\n\" +\n                  \"Vui lòng kiểm tra lại thiết bị ngay!\";\n    return msg;\n}\n\n// Nếu hệ thống đã Bình thường trở lại, xóa bộ nhớ tạm để sẵn sàng cho đợt lỗi tiếp theo\nif (!isCritical) {\n    flow.set(\"lastEmailAlert\", \"\");\n}\n\nreturn null;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 840,
