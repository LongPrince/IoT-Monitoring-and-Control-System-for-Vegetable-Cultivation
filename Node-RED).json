    {
        "id": "e087ae98773ed4e1",
        "type": "function",
        "z": "smart_farm_pro_tab",
        "name": "Xử lý Config (Có Reset Dropdown)",
        "func": "if (msg.topic === \"mode\") flow.set(\"mode\", msg.payload);\nif (msg.topic === \"crop\") flow.set(\"cropKey\", msg.payload);\n\nlet mode = flow.get(\"mode\");\nlet cropKey = flow.get(\"cropKey\");\n\n// NẾU CHỌN \"----\" HOẶC CHƯA CHỌN: ĐƯA HỆ THỐNG VỀ CHẾ ĐỘ CHỜ (WAIT)\nif (mode === \"WAIT\" || cropKey === \"NONE\" || !mode || !cropKey) {\n    let msgMqtt = {\n        payload: {\n            cmd: \"update_config\",\n            mode: \"WAIT\",\n            crop: \"Waiting...\",\n            min: 0,\n            max: 0\n        }\n    };\n    let msgFirebase = {\n        payload: {\n            activeCrop: \"Chưa chọn\",\n            mode: \"WAIT\"\n        }\n    };\n    return [msgMqtt, msgFirebase];\n}\n\n// Nếu đã chọn đầy đủ thông tin hợp lệ:\nlet cropsDB = {\n   \"ca_chua\": { name: \"Ca Chua\", min: 50, max: 65 },\n   \"cai_be_xanh\": { name: \"Cải Bẹ Xanh\", min: 40, max: 70 },\n   \"rau_muong\": { name: \"Rau Muống\", min: 60, max: 80 }\n};\nlet c = cropsDB[cropKey];\n\nlet msgMqtt = {\n    payload: {\n        cmd: \"update_config\",\n        mode: mode,\n        crop: c.name,\n        min: c.min,\n        max: c.max\n    }\n};\nlet msgFirebase = {\n    payload: { activeCrop: cropKey, mode: mode }\n};\n\nreturn [msgMqtt, msgFirebase];",
        "outputs": 2,
        "x": 580,
        "y": 940,
        "wires": [
