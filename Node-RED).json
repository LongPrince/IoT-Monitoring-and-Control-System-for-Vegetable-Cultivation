    {
        "id": "7b63eea8a0f9b0eb",
        "type": "function",
        "z": "smart_farm_pro_tab",
        "name": "Tách Luồng Dữ Liệu ESP32",
        "func": "let p = msg.payload;\nlet d = new Date();\nd.setHours(d.getHours() + 7);\nlet ts = d.toISOString().replace('T', ' ').substring(0, 19);\n\n// 1. Nhánh Sensors\nlet msgSensors = {\n    payload: { temp: p.temp, humi: p.humi, soil: p.soil, ldr: p.ldr, lastUpdate: ts }\n};\n\n// 2. Nhánh Alerts\nlet msgAlerts = {\n    payload: { status: p.alert, isCritical: (p.alert !== \"Bình thường\") }\n};\n\n// 3. Nhánh Control (Cập nhật thực tế từ ESP32)\nlet msgControl = {\n    payload: { pump: p.pump, light: p.light, roof: p.roof }\n};\n\n// --- UI DASHBOARD ---\nlet uiTemp = { payload: p.temp };\nlet uiHumi = { payload: p.humi };\nlet uiSoil = { payload: p.soil };\nlet uiAlert = { payload: p.alert };\nlet uiStatus = { payload: `Bơm: ${p.pump} | Đèn: ${p.light} | Mái: ${p.roof}` };\n\nreturn [msgSensors, msgAlerts, msgControl, uiTemp, uiHumi, uiSoil, uiAlert, uiStatus];",
        "outputs": 8,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 560,
        "y": 640,
        "wires": [
